-- 1. Criar a tabela de Usuários primeiro (porque o personagem vai precisar dela)
CREATE TABLE users (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    username VARCHAR(50) NOT NULL UNIQUE,
    email VARCHAR(255) NOT NULL UNIQUE,
    password_hash TEXT NOT NULL,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- 2. Criar a tabela de Personagens conectada aos Usuários
CREATE TABLE characters (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID NOT NULL, -- Coluna que vai guardar o ID do dono da ficha
    name VARCHAR(100) NOT NULL,
    nex INTEGER DEFAULT 5, -- Todo personagem começa com NEX 5% por padrão
    classe VARCHAR(30) NOT NULL, -- Combatente, Especialista, Ocultista
    
    -- Atributos principais do sistema Ordem Paranormal
    forca INTEGER DEFAULT 1,
    agilidade INTEGER DEFAULT 1,
    intelecto INTEGER DEFAULT 1,
    presenca INTEGER DEFAULT 1,
    vigor INTEGER DEFAULT 1,
    
    -- Pontos de Vida, Sanidade e Esforço
    pv_max INTEGER NOT NULL,
    pv_atual INTEGER NOT NULL,
    san_max INTEGER NOT NULL,
    san_atual INTEGER NOT NULL,
    pe_max INTEGER NOT NULL,
    pe_atual INTEGER NOT NULL,

    -- Aqui criamos o Relacionamento: user_id nesta tabela APONTA para o id da tabela users
    CONSTRAINT fk_user FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);
